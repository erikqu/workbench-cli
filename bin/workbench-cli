#!/usr/bin/env bash
set -euo pipefail

# Resolve this script through any symlinks (e.g. ~/.local/bin/workbench-cli).
SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  TARGET="$(readlink "$SOURCE")"
  if [[ "$TARGET" == /* ]]; then
    SOURCE="$TARGET"
  else
    SOURCE="$DIR/$TARGET"
  fi
done

BIN_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
# Package root holds the workbench-ui workbench.
PKG_DIR="$(cd -P "$BIN_DIR/.." && pwd)"
UI_DIR="$PKG_DIR/workbench-ui"

if ! command -v bun >/dev/null 2>&1; then
  echo "workbench-cli requires bun on PATH." >&2
  exit 1
fi

# Silvery's Scope class extends AsyncDisposableStack while its module is being
# evaluated. Detect an old Bun here so users get a useful recovery instruction
# instead of a dependency stack trace.
if ! bun -e 'process.exit(typeof AsyncDisposableStack === "function" ? 0 : 1)' >/dev/null 2>&1; then
  echo "workbench-cli requires a newer Bun (found $(bun --version))." >&2
  echo "Upgrade Bun or re-run: curl -fsSL https://ehq.so/install | bash" >&2
  exit 1
fi

if [[ ! -d "$UI_DIR" ]]; then
  echo "Missing workbench-ui directory: $UI_DIR" >&2
  exit 1
fi

# Hot reload (opt-in): restart the workbench whenever its TypeScript source
# changes, so edits or updates to workbench-cli take effect without a manual
# relaunch. Enable with WORKBENCH_CLI_HOT=1 or by passing --hot (aliases: --dev,
# --watch).
#
# The application-owned hot runner watches source files, sends SIGTERM to the
# current UI, waits for it to save and detach, then launches the replacement.
# Do not replace it with Bun's native --watch: native watch restarts do not
# guarantee Workbench's shutdown handoff and can reset active coding sessions.
hot="${WORKBENCH_CLI_HOT:-0}"
terminal_trace="${WORKBENCH_TERMINAL_TRACE:-0}"
args=()
for arg in "$@"; do
  case "$arg" in
    --hot | --dev | --watch) hot=1 ;;
    --terminal-trace) terminal_trace=1 ;;
    *) args+=("$arg") ;;
  esac
done

entry="$UI_DIR/src/index.ts"
if [[ "$hot" == "1" ]]; then
  entry="$UI_DIR/scripts/hot-runner.ts"
fi

exec env -u NO_COLOR \
  COLORTERM="${COLORTERM:-truecolor}" \
  FORCE_COLOR=1 \
  WORKBENCH_CLI_HOT="$hot" \
  WORKBENCH_TERMINAL_TRACE="$terminal_trace" \
  WORKBENCH_UI_CWD="${WORKBENCH_UI_CWD:-$PWD}" \
  bun "$entry" ${args[@]+"${args[@]}"}
